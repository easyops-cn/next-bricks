          "type": "boolean"
        },
        {
          "name": "startColor",
          "description": "渐变色起始颜色",
          "type": "string"
        },
        {
          "name": "endColor",
          "description": "渐变色终止颜色",
          "type": "string"
        },
        {
          "name": "gradientDirection",
          "description": "渐变色方向",
          "type": "GradientDirection"
        }
      ],
      "events": [],
      "slots": [],
