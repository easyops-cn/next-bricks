{
  "manifest_version": 1,
  "package": "@next-bricks/icons",
  "name": "icons",
  "bricks": [
    {
      "name": "icons.antd-icon",
      "properties": [
        {
          "name": "theme",
          "description": "图标主题",
          "default": "\"outlined\"",
          "type": "string"
        },
        {
          "name": "icon",
          "description": "图标名",
