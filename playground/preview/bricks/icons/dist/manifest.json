          "default": "\"fas\"",
          "type": "string"
        },
        {
          "name": "startColor",
          "description": "渐变色起始颜色（不适用于 EasyOps 图标）",
          "type": "string"
        },
        {
          "name": "endColor",
          "description": "渐变色终止颜色（不适用于 EasyOps 图标）",
          "type": "string"
        },
        {
          "name": "gradientDirection",
          "description": "渐变色方向（不适用于 EasyOps 图标）",
          "type": "GradientDirection"
        }
      ],
      "events": [],
      "slots": [],
      "methods": []
