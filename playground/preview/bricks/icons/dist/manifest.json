    {
      "name": "icons.general-icon",
      "properties": [
        {
          "name": "lib",
          "description": "图标库",
          "type": "\"antd\" | \"easyops\" | \"fa\""
        },
        {
          "name": "theme",
          "description": "Ant Design 图标主题",
          "default": "\"outlined\"",
          "type": "string"
